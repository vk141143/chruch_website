# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Stripe (used in Edge Functions, NOT exposed to frontend) ──────────────────
# Set via: supabase secrets set STRIPE_SECRET_KEY=sk_live_...
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_MONTHLY=price_...   (from Stripe Dashboard > Products)
# STRIPE_PRICE_ANNUAL=price_...

# ── Stripe Payment Links (fallback if Edge Functions not deployed yet) ────────
# These go inside SubscriptionModal.tsx > PLANS array
# VITE_STRIPE_MONTHLY_LINK=https://buy.stripe.com/your_monthly_link
# VITE_STRIPE_ANNUAL_LINK=https://buy.stripe.com/your_annual_link

# ── Site URL (used by Edge Function for redirect after payment) ───────────────
# SITE_URL=https://your-domain.com
